{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/main.tsx", "src/App.tsx", "src/lib/expenses-data.ts"],
  "exclude": [
    "src/routes",
    "src/router.tsx",
    "src/routeTree.gen.ts",
    "src/start.ts",
    "src/server.ts",
    "src/hooks",
    "src/components",
    "src/lib/utils.ts",
    "src/lib/error-capture.ts",
    "src/lib/error-page.ts",
    "src/lib/lovable-error-reporting.ts"
  ]
}
